const formatName = (name: string) => {
  return name
    .toLowerCase()
    .split(" ")
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};
---

<div id="RecordingLine">
	<main>
		<h1>Fila de gravação!</h1>
		
		<br/>

		<h4>Colaboradores das categorias Força Gabuzinho de Cris Cris ordenados a serem convidados para as próximas gravações.</h4>
		
		<br/>

		<ul>
			{recordingLine.map((name, index) => (
			<li>
				<span class="lineIndex">{index + 1}</span>
				<span class="lineName">{formatName(name)}</span>
			</li>
			))}
		</ul>

		<br/>

		<h5>Muito obrigado mais uma vez pela força que deram pra mim e pro meu cachorro.</h4> 
        
        <br/>
    
        <h1>Vocês são incríveis.</h1>
	</main>
</div>

<style>
	div {
		background-color: var(--azul-medio);
	}

	main {
		padding: 3em auto;
	}

	ul {
		text-align: center;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	
	.lineIndex {
		font-weight: bolder;
		color: var(--ciano);
	}

	.lineName {
		color: var(--branco);
	}

	h1 {
		text-align: center;
		color: var(--amarelo);
		margin: auto;
	}

	h4 {
		text-align: center;
		color: var(--branco);
		margin: 0 auto;
	}
	
	h5 {
		text-align: center;
		color: var(--branco);
		margin: 0 auto;
	}

	p {
		text-align: center;
		color: var(--branco);
		margin: 1em auto 0;
	}

	.icons {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1em;
		margin: 0 auto;
	}

	.icons a {
		text-decoration: none;
		color: var(--amarelo);
	}

	.icons a:hover {
		color: var(--ciano);
	}

	blockquote {
		color: var(--amarelo);
		border-left: 4px solid var(--branco);
	}
	
	a {
		color: var(--amarelo);
	}

	a:hover {
		color: var(--ciano);
	}
</style>
